{
  "name": "heard-local-scheduler",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build": "rm -rf dist && bun build src/bundle.js --outdir=dist --minify --format=iife",
    "build:legacy": "rm -rf dist && bun build scheduler-redirect-new.js webflow-scheduler-complete-new.js form.css --outdir=dist --minify",
    "build:all": "bun run build && bun run build:legacy",
    "dev": "bun build src/bundle.js --outdir=dist --format=iife --watch",
    "lint": "eslint src/ --ext .js",
    "format": "prettier --write src/ **/*.js",
    "type-check": "tsc --noEmit",
    "test": "bun test",
    "clean": "rm -rf dist node_modules .turbo"
  },
  "devDependencies": {
    "@types/bun": "^1.0.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.5",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}